---
import { categoryLabels, safetyLabels, type Spot } from '../data/spots';

interface Props {
  spot: Spot;
}

const { spot } = Astro.props;
---

<a class="spot-card" href={`/spots/${spot.slug}/`} data-category={spot.category}>
  <article class="inner">
    <div class="pic">
      <img src={spot.img} alt={spot.name} loading="lazy" decoding="async" />
      <span class="cat">{categoryLabels[spot.category]}</span>
    </div>
    <div class="body">
      <span class="eyebrow">{spot.area}</span>
      <h3>{spot.name}</h3>
      <p class="blurb">{spot.blurb}</p>
      <span class="plate">{spot.price}</span>
      <div class="safety-row">
        <span class={`safety-dot ${spot.safetyDay}`}>Day: {safetyLabels[spot.safetyDay].label}</span>
        <span class={`safety-dot ${spot.safetyNight}`}>Night: {safetyLabels[spot.safetyNight].label}</span>
      </div>
    </div>
  </article>
</a>

<style>
  /* The card queries ITS OWN width, not the viewport — a full-width card on a
     landscape phone goes horizontal; the same card in a narrow grid column stays stacked. */
  .spot-card {
    display: block;
    container-type: inline-size;
    container-name: spotcard;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 0.9rem;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease;
  }
  .spot-card:hover { transform: translateY(-4px); border-color: var(--danfo); }

  .inner { display: flex; flex-direction: column; height: 100%; }

  .pic { position: relative; aspect-ratio: 16 / 10; flex-shrink: 0; }
  .pic img { width: 100%; height: 100%; object-fit: cover; }
  .cat {
    position: absolute; top: 0.7rem; left: 0.7rem;
    font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    background: rgba(11,10,14,0.75); border: 1px solid var(--line);
    border-radius: 999px; padding: 0.25rem 0.6rem; backdrop-filter: blur(4px);
  }

  .body { display: flex; flex-direction: column; flex-grow: 1; padding: var(--space-md); }
  .eyebrow {
    font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--text-dim);
  }
  h3 { font-family: var(--font-display); font-size: clamp(1.1rem, 4.5cqi, 1.4rem); font-weight: 600; margin-top: 0.3rem; }
  .blurb { margin-top: 0.45rem; font-size: var(--text-sm); color: var(--text-dim); flex-grow: 1; }
  .plate { margin-top: var(--space-sm); align-self: flex-start; font-size: 0.72rem; }

  .safety-row {
    display: flex; flex-wrap: wrap; gap: 0.3rem 1rem; margin-top: 0.8rem;
    font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-dim);
  }
  .safety-dot { display: inline-flex; align-items: center; gap: 0.4rem; }
  .safety-dot::before {
    content: ''; width: 0.55rem; height: 0.55rem; border-radius: 50%;
  }
  .safety-dot.good::before { background: var(--safe); box-shadow: 0 0 8px var(--safe); }
  .safety-dot.caution::before { background: var(--watch); box-shadow: 0 0 8px var(--watch); }
  .safety-dot.avoid::before { background: var(--avoid); box-shadow: 0 0 8px var(--avoid); }

  /* Wide container → horizontal card, image on the left */
  @container spotcard (min-width: 30rem) {
    .inner { flex-direction: row; }
    .pic { width: 42%; aspect-ratio: auto; min-height: 100%; }
    .body { padding: var(--space-md) var(--space-lg) var(--space-md) var(--space-md); }
  }

  @container spotcard (min-width: 42rem) {
    .pic { width: 36%; }
    .blurb { font-size: var(--text-base); }
  }
</style>
