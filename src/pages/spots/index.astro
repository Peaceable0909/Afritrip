---
import Cinematic from '../../layouts/Cinematic.astro';
import SpotCard from '../../components/SpotCard.astro';
import { spots, categoryLabels, type Category } from '../../data/spots';

const categories = Object.keys(categoryLabels) as Category[];
---

<Cinematic title="All spots — Waka" description="Every Waka spot: real prices, honest safety notes, curated by people wey sabi road.">
  <section class="listing">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>›</span> <a href="/states/lagos/">Lagos</a> <span>›</span> <b>Spots</b>
    </nav>

    <div class="head">
      <p class="script kicker">Spots wey sure</p>
      <h1>Every spot, one honest list</h1>
      <p class="sub">
        {spots.length} places in Lagos — each with the price locals pay and a
        straight-talk safety note for day and night.
      </p>
    </div>

    <div class="chip-row" role="group" aria-label="Filter by category">
      <button class="chip" data-cat="all" aria-pressed="true">All</button>
      {categories.map((cat) => (
        <button class="chip" data-cat={cat} aria-pressed="false">
          {categoryLabels[cat]}
        </button>
      ))}
    </div>

    <div class="spot-grid" id="spot-grid">
      {spots.map((spot) => <SpotCard spot={spot} />)}
    </div>
  </section>
</Cinematic>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const cards = document.querySelectorAll<HTMLElement>('.spot-card');

  function applyFilter(cat: string) {
    chips.forEach((chip) =>
      chip.setAttribute('aria-pressed', String(chip.dataset.cat === cat))
    );
    cards.forEach((card) => {
      card.style.display =
        cat === 'all' || card.dataset.category === cat ? '' : 'none';
    });
  }

  chips.forEach((chip) =>
    chip.addEventListener('click', () => {
      const cat = chip.dataset.cat ?? 'all';
      applyFilter(cat);
      const url = new URL(window.location.href);
      if (cat === 'all') url.searchParams.delete('cat');
      else url.searchParams.set('cat', cat);
      history.replaceState(null, '', url);
    })
  );

  const initial = new URLSearchParams(window.location.search).get('cat');
  if (initial && [...chips].some((c) => c.dataset.cat === initial)) {
    applyFilter(initial);
  }
</script>

<style>
  .listing { padding: 6.5rem clamp(1rem, 4vw, 3rem) 4.5rem; }
  .crumbs {
    font-size: 0.82rem; color: var(--text-dim);
    display: flex; gap: 0.5rem; align-items: center; margin-bottom: 2rem;
  }
  .crumbs a { text-decoration: none; }
  .crumbs a:hover { color: var(--text); }
  .crumbs b { color: var(--danfo); font-weight: 600; }

  .head { margin-bottom: 2rem; }
  .kicker { font-size: clamp(1.4rem, 3.5vw, 2rem); color: var(--danfo); }
  h1 { font-family: var(--font-display); font-size: clamp(1.9rem, 5vw, 3rem); font-weight: 800; margin-top: 0.3rem; }
  .sub { margin-top: 0.8rem; color: var(--text-dim); max-width: 52ch; }

  .chip-row { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2rem; }
  .chip {
    font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 0.5rem 1.1rem; border-radius: 999px;
    border: 1px solid var(--line); background: var(--panel); color: var(--text);
    cursor: pointer;
    min-height: 44px; min-width: 44px;
  }
  .chip:hover { border-color: var(--danfo); }
  .chip[aria-pressed='true'] {
    background: var(--danfo); color: #191410; border-color: #191410;
    box-shadow: 2px 2px 0 #000;
  }

  .spot-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(min(19rem, 100%), 1fr));
    gap: 1.25rem;
  }
</style>
