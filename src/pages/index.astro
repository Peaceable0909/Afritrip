---
import Cinematic from '../layouts/Cinematic.astro';

const cities = [
  { slug: 'lagos', name: 'Lagos', tag: 'The city that never sleeps', img: '/img/cinematic/city-lagos.jpg', href: '/states/lagos/' },
  { slug: 'abuja', name: 'Abuja', tag: 'The heart of Nigeria', img: '/img/cinematic/city-abuja.jpg', href: '/states/abuja/' },
  { slug: 'calabar', name: 'Calabar', tag: "Nature's paradise", img: '/img/cinematic/city-calabar.jpg', href: '/states/calabar/' },
  { slug: 'kano', name: 'Kano', tag: 'Ancient & timeless', img: '/img/cinematic/city-kano.jpg', href: '/states/kano/' },
  { slug: 'osun', name: 'Osun', tag: 'Cultural heritage', img: '/img/cinematic/city-osun.jpg', href: '/states/osun/' },
];

const categories = [
  { name: 'Beaches', sub: 'Stunning coastlines', color: 'var(--danfo)' },
  { name: 'Adventures', sub: 'Thrills & nature', color: 'var(--neon-green)' },
  { name: 'Culture', sub: 'Traditions & festivals', color: 'var(--neon-pink)' },
  { name: 'Food', sub: 'A taste of Nigeria', color: 'var(--danfo)' },
  { name: 'Nightlife', sub: 'Party all night', color: 'var(--neon-teal)' },
];
---

<Cinematic title="Waka — Welcome to Nigeria">
  <section class="hero">
    <img class="hero-bg" src="/img/cinematic/hero-home.jpg" alt="" fetchpriority="high" />
    <div class="hero-shade" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="script welcome">Welcome to</p>
      <h1>NIGERIA</h1>
      <p class="lede">
        A land of vibrant cultures, breathtaking landscapes, rich history and
        unforgettable experiences.
      </p>
      <div class="hero-ctas">
        <a class="btn-solid" href="#explore">Start Exploring</a>
        <a class="btn-play" href="/states/lagos/">
          <span class="play" aria-hidden="true">▶</span> Watch Nigeria Reel
        </a>
      </div>
    </div>
    <p class="scroll-hint" aria-hidden="true">Scroll to explore</p>
  </section>

  <section class="stats" id="states">
    <div class="stat" data-reveal><b>36</b><span>States &amp; FCT</span></div>
    <div class="stat" data-reveal><b>1000+</b><span>Destinations</span></div>
    <div class="stat" data-reveal><b>Live</b><span>Events</span></div>
    <div class="stat" data-reveal><b>Plan</b><span>Your Trip</span></div>
    <div class="stat" data-reveal><b>Inspire</b><span>Travel Guide</span></div>
  </section>

  <section class="explore" id="explore">
    <div class="explore-head">
      <h2 class="script">Explore Nigeria</h2>
      <p>From bustling cities to serene landscapes, every corner of Nigeria has a story to tell.</p>
    </div>
    <div class="city-row">
      {cities.map((c) => (
        <a class="city-card" href={c.href} data-reveal>
          <img src={c.img} alt={`${c.name} — ${c.tag}`} loading="lazy" />
          <div class="city-meta">
            <strong>{c.name}</strong>
            <span>{c.tag}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="cats" id="categories">
    {categories.map((cat) => (
      <div class="cat" data-reveal>
        <span class="script cat-name" style={`color:${cat.color}`}>{cat.name}</span>
        <span class="cat-sub">{cat.sub}</span>
      </div>
    ))}
  </section>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis();
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      // entrance: the hero paints itself in
      gsap.timeline()
        .from('.welcome', { opacity: 0, y: 20, duration: 0.7, ease: 'power2.out' })
        .from('.hero h1', { opacity: 0, y: 34, duration: 0.8, ease: 'power2.out' }, 0.15)
        .from('.lede, .hero-ctas', { opacity: 0, y: 24, stagger: 0.12, duration: 0.7, ease: 'power2.out' }, 0.4);

      // hero parallax: image drifts slower than the page, content lifts away
      gsap.to('.hero-bg', {
        yPercent: 18,
        scale: 1.08,
        ease: 'none',
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to('.hero-content', {
        yPercent: -14,
        opacity: 0.15,
        ease: 'none',
        scrollTrigger: { trigger: '.hero', start: 'top top', end: '75% top', scrub: true },
      });

      // shared reveal for stats, city cards, categories
      document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el, i) => {
        gsap.from(el, {
          opacity: 0,
          y: 36,
          duration: 0.7,
          ease: 'power2.out',
          delay: (i % 5) * 0.08,
          scrollTrigger: { trigger: el, start: 'top 88%' },
        });
      });

      // section headings slide in from the left
      gsap.from('.explore-head', {
        opacity: 0,
        x: -40,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: { trigger: '.explore-head', start: 'top 85%' },
      });
    }
  </script>

  <style>
    .hero { position: relative; min-height: 100vh; min-height: 100dvh; display: grid; align-items: center; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
    .hero-shade {
      position: absolute; inset: 0;
      background:
        linear-gradient(90deg, rgba(11,10,14,0.82) 0%, rgba(11,10,14,0.35) 45%, rgba(11,10,14,0.1) 70%),
        linear-gradient(180deg, rgba(11,10,14,0.3) 0%, rgba(11,10,14,0) 30%, rgba(11,10,14,0.9) 100%);
    }
    .hero-content { position: relative; padding: 6rem clamp(1.25rem, 6vw, 5rem) 4rem; max-width: 44rem; }
    .welcome {
      font-size: clamp(1.6rem, 4vw, 2.4rem); color: var(--danfo);
      text-shadow: 0 2px 16px rgba(0,0,0,0.6); margin-bottom: -0.4rem;
    }
    .hero h1 {
      font-family: var(--font-display); font-weight: 800;
      font-size: clamp(3.4rem, 12vw, 8rem); line-height: 0.95; letter-spacing: 0.01em;
      background: linear-gradient(100deg, #3f9e63 8%, #f3efe6 38%, #f0a04a 75%, #d96b2f 100%);
      -webkit-background-clip: text; background-clip: text; color: transparent;
      filter: drop-shadow(0 4px 22px rgba(0,0,0,0.55));
    }
    .lede { margin-top: 1.2rem; max-width: 40ch; font-size: 1.05rem; color: var(--text); text-shadow: 0 1px 10px rgba(0,0,0,0.7); }
    .hero-ctas { display: flex; flex-wrap: wrap; align-items: center; gap: 1.2rem; margin-top: 2rem; }
    .btn-solid {
      background: var(--danfo); color: #191410; font-weight: 700; text-decoration: none;
      padding: 0.8rem 1.6rem; border-radius: 999px; border: 2px solid #191410; box-shadow: 3px 3px 0 #000;
    }
    .btn-solid:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 #000; }
    .btn-play { display: inline-flex; align-items: center; gap: 0.7rem; text-decoration: none; font-weight: 600; font-size: 0.95rem; text-shadow: 0 1px 8px rgba(0,0,0,0.8); }
    .play {
      display: grid; place-content: center; width: 2.6rem; height: 2.6rem; border-radius: 50%;
      border: 2px solid rgba(243,239,230,0.7); font-size: 0.7rem; padding-left: 2px;
    }
    .btn-play:hover .play { border-color: var(--danfo); color: var(--danfo); }
    .scroll-hint {
      position: absolute; bottom: 1.4rem; left: 50%; transform: translateX(-50%);
      font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: rgba(243,239,230,0.75);
    }

    .stats {
      display: grid; grid-template-columns: repeat(5, 1fr);
      border-block: 1px solid var(--line);
      background: rgba(22,20,28,0.6); backdrop-filter: blur(8px);
      margin-top: -4.5rem; position: relative; z-index: 2;
      margin-inline: clamp(1rem, 4vw, 3rem); border: 1px solid var(--line); border-radius: 1rem;
      overflow: hidden;
    }
    .stat { display: grid; gap: 0.1rem; place-items: center; padding: 1.3rem 0.5rem; text-align: center; }
    .stat + .stat { border-left: 1px solid var(--line); }
    .stat b { font-family: var(--font-mono); font-size: 1.15rem; color: var(--danfo); }
    .stat span { font-size: 0.78rem; color: var(--text-dim); }

    .explore { padding: 5rem clamp(1rem, 4vw, 3rem) 3rem; }
    .explore-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 1.5rem; margin-bottom: 2rem; }
    .explore-head h2 {
      font-size: clamp(2rem, 5vw, 3rem); color: var(--text); font-weight: 400;
      text-decoration: underline; text-decoration-color: var(--neon-pink); text-decoration-thickness: 3px; text-underline-offset: 10px;
    }
    .explore-head p { color: var(--text-dim); max-width: 34ch; font-size: 0.95rem; }
    .city-row {
      display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem;
    }
    .city-card {
      position: relative; border-radius: 0.9rem; overflow: hidden; text-decoration: none;
      aspect-ratio: 4 / 5; border: 1px solid var(--line);
      transition: transform 0.18s ease;
    }
    .city-card img { width: 100%; height: 100%; object-fit: cover; }
    a.city-card:hover { transform: translateY(-5px); border-color: var(--danfo); }
    .city-meta {
      position: absolute; inset: auto 0 0 0; padding: 2.2rem 0.9rem 0.9rem;
      background: linear-gradient(180deg, transparent, rgba(0,0,0,0.85));
      display: grid; gap: 0.05rem;
    }
    .city-meta strong { font-family: var(--font-display); font-size: 1.15rem; }
    .city-meta span { font-size: 0.75rem; color: var(--text-dim); }
    .cats {
      display: grid; grid-template-columns: repeat(5, 1fr);
      border-top: 1px solid var(--line);
      padding: 2.2rem clamp(1rem, 4vw, 3rem); gap: 1rem;
    }
    .cat { display: grid; gap: 0.15rem; place-items: center; text-align: center; }
    .cat-name { font-size: 1.3rem; text-shadow: 0 0 18px currentColor; }
    .cat-sub { font-size: 0.75rem; color: var(--text-dim); }

    @media (max-width: 56rem) {
      .stats { grid-template-columns: repeat(2, 1fr); margin-top: 0; border-radius: 0; margin-inline: 0; border-inline: none; }
      .stat:nth-child(odd) { border-left: none; }
      .stat:nth-child(5) { grid-column: span 2; border-left: none; border-top: 1px solid var(--line); }
      .city-row { grid-template-columns: repeat(2, 1fr); }
      .city-card:last-child { grid-column: span 2; aspect-ratio: 16 / 9; }
      .cats { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</Cinematic>
