---
import Cinematic from '../layouts/Cinematic.astro';

const cities = [
  { slug: 'lagos', name: 'Lagos', tag: 'The city that never sleeps', img: '/img/cinematic/city-lagos.jpg', href: '/states/lagos/' },
  { slug: 'abuja', name: 'Abuja', tag: 'The heart of Nigeria', img: '/img/cinematic/city-abuja.jpg', href: '/states/abuja/' },
  { slug: 'calabar', name: 'Calabar', tag: "Nature's paradise", img: '/img/cinematic/city-calabar.jpg', href: '/states/calabar/' },
  { slug: 'kano', name: 'Kano', tag: 'Ancient & timeless', img: '/img/cinematic/city-kano.jpg', href: '/states/kano/' },
  { slug: 'osun', name: 'Osun', tag: 'Cultural heritage', img: '/img/cinematic/city-osun.jpg', href: '/states/osun/' },
];

const categories = [
  { name: 'Beaches', sub: 'Stunning coastlines', color: 'var(--danfo)' },
  { name: 'Adventures', sub: 'Thrills & nature', color: 'var(--neon-green)' },
  { name: 'Culture', sub: 'Traditions & festivals', color: 'var(--neon-pink)' },
  { name: 'Food', sub: 'A taste of Nigeria', color: 'var(--danfo)' },
  { name: 'Nightlife', sub: 'Party all night', color: 'var(--neon-teal)' },
];
---

<Cinematic title="Waka — Welcome to Nigeria">
  <section class="hero">
    <div class="bg-wrap" aria-hidden="true">
      <img class="bg-img" src="/img/cinematic/hero-land.jpg" alt="" fetchpriority="high" />
    </div>

    <img class="clouds" src="/img/cinematic/hero-clouds.jpg" alt="" aria-hidden="true" />

    <svg class="birds" viewBox="0 0 120 40" aria-hidden="true">
      <g fill="none" stroke="#1a140f" stroke-width="2" stroke-linecap="round">
        <path d="M10 20 Q16 12 22 18 Q28 12 34 20" />
        <path d="M50 10 Q55 4 60 9 Q65 4 70 10" opacity="0.85" />
        <path d="M84 28 Q88 23 92 27 Q96 23 100 28" opacity="0.7" />
      </g>
    </svg>

    <h1 class="word">NIGERIA</h1>

    <img class="splash" src="/img/cinematic/hero-splash.jpg" alt="" aria-hidden="true" />

    <img
      class="portrait"
      src="/img/cinematic/hero-portrait.png"
      alt="Nigerian woman in a colorful gele headwrap"
      fetchpriority="high"
    />

    <div class="mist" aria-hidden="true"></div>

    <div class="dust" aria-hidden="true">
      {Array.from({ length: 16 }).map((_, i) => (
        <span
          style={`left:${(i * 61) % 100}%; top:${((i * 37) % 70) + 12}%; animation-delay:${(i * 0.7) % 6}s; animation-duration:${5 + (i % 5)}s`}
        />
      ))}
    </div>

    <div class="copy">
      <p class="script welcome">Welcome to</p>
      <p class="lede">
        A land of vibrant cultures, breathtaking landscapes, rich history and
        unforgettable experiences.
      </p>
      <div class="hero-ctas">
        <a class="btn-solid" href="#explore">Start Exploring</a>
        <a class="btn-play" href="/states/lagos/">
          <span class="play" aria-hidden="true">▶</span> Watch Nigeria Reel
        </a>
      </div>
    </div>

    <div class="grade" aria-hidden="true"></div>
    <p class="scroll-hint" aria-hidden="true">Scroll to explore</p>
  </section>

  <section class="stats" id="states">
    <div class="stat" data-reveal><b>36</b><span>States &amp; FCT</span></div>
    <div class="stat" data-reveal><b>1000+</b><span>Destinations</span></div>
    <div class="stat" data-reveal><b>Live</b><span>Events</span></div>
    <div class="stat" data-reveal><b>Plan</b><span>Your Trip</span></div>
    <div class="stat" data-reveal><b>Inspire</b><span>Travel Guide</span></div>
  </section>

  <section class="explore" id="explore">
    <div class="explore-head">
      <h2 class="script">Explore Nigeria</h2>
      <p>From bustling cities to serene landscapes, every corner of Nigeria has a story to tell.</p>
    </div>
    <div class="city-row">
      {cities.map((c) => (
        <a class="city-card" href={c.href} data-reveal>
          <img src={c.img} alt={`${c.name} — ${c.tag}`} loading="lazy" />
          <div class="city-meta">
            <strong>{c.name}</strong>
            <span>{c.tag}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="cats" id="categories">
    {categories.map((cat) => (
      <div class="cat" data-reveal>
        <span class="script cat-name" style={`color:${cat.color}`}>{cat.name}</span>
        <span class="cat-sub">{cat.sub}</span>
      </div>
    ))}
  </section>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis();
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      // entrance: the scene assembles like a film title
      gsap.timeline()
        .from('.word', { opacity: 0, y: 50, duration: 1, ease: 'power3.out' })
        .from('.splash', { opacity: 0, scale: 0.6, duration: 0.9, ease: 'power2.out' }, 0.35)
        .from('.portrait', { opacity: 0, y: 90, duration: 1, ease: 'power3.out' }, 0.45)
        .from('.welcome', { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' }, 0.9)
        .from('.lede, .hero-ctas', { opacity: 0, y: 22, stagger: 0.12, duration: 0.6, ease: 'power2.out' }, 1.05);

      // scroll parallax: every layer moves at its own depth
      const heroScrub = { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: true };
      gsap.to('.bg-wrap', { yPercent: 14, ease: 'none', scrollTrigger: heroScrub });
      gsap.to('.word', { yPercent: -60, ease: 'none', scrollTrigger: heroScrub });
      gsap.to('.portrait', { yPercent: 10, ease: 'none', scrollTrigger: heroScrub });
      gsap.to('.splash', { yPercent: 22, ease: 'none', scrollTrigger: heroScrub });
      gsap.to('.copy', {
        yPercent: -30,
        opacity: 0,
        ease: 'none',
        scrollTrigger: { trigger: '.hero', start: 'top top', end: '70% top', scrub: true },
      });

      // shared reveal for stats, city cards, categories
      document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el, i) => {
        gsap.from(el, {
          opacity: 0,
          y: 36,
          duration: 0.7,
          ease: 'power2.out',
          delay: (i % 5) * 0.08,
          scrollTrigger: { trigger: el, start: 'top 88%' },
        });
      });

      // section headings slide in from the left
      gsap.from('.explore-head', {
        opacity: 0,
        x: -40,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: { trigger: '.explore-head', start: 'top 85%' },
      });
    }
  </script>

  <style>
    .hero { position: relative; height: 100vh; height: 100dvh; overflow: hidden; }

    /* L1 — landscape (GSAP parallax on wrapper, ambient Ken Burns zoom on img) */
    .bg-wrap { position: absolute; inset: -6% 0; z-index: 1; }
    .bg-img { width: 100%; height: 100%; object-fit: cover; object-position: center 40%; animation: kenburns 28s ease-in-out infinite alternate; }
    @keyframes kenburns { from { transform: scale(1); } to { transform: scale(1.07); } }

    /* L2 — drifting clouds (screen blend kills the black) */
    .clouds {
      position: absolute; top: -3%; left: -10%; width: 130%; z-index: 2;
      mix-blend-mode: screen; opacity: 0.5;
      animation: drift 70s ease-in-out infinite alternate;
    }
    @keyframes drift { from { transform: translateX(0); } to { transform: translateX(-8%); } }

    /* L3 — birds crossing the sky */
    .birds {
      position: absolute; top: 16%; left: 0; width: clamp(5rem, 9vw, 8rem); z-index: 2;
      animation: fly 42s linear infinite;
    }
    @keyframes fly {
      0% { transform: translate(-15vw, 0); }
      50% { transform: translate(50vw, -4vh); }
      100% { transform: translate(115vw, 1vh); }
    }

    /* L4 — the wordmark: landscape inside the letters, grunge scratched over it */
    .word {
      position: absolute; inset: 12% 0 auto 0; z-index: 3; margin: 0;
      text-align: center;
      font-family: var(--font-display); font-weight: 800;
      font-size: clamp(4.2rem, 16.5vw, 15rem); line-height: 0.9; letter-spacing: 0.01em;
      background-image: url('/img/cinematic/hero-grunge.jpg'), url('/img/cinematic/hero-land.jpg');
      background-size: cover, 145% auto;
      background-position: center, center 12%;
      background-blend-mode: soft-light;
      -webkit-background-clip: text; background-clip: text; color: transparent;
      filter: saturate(1.35) contrast(1.1) brightness(1.32) drop-shadow(0 8px 34px rgba(0,0,0,0.65));
    }

    /* L5 — paint splash halo behind the portrait */
    .splash {
      position: absolute; right: -6%; bottom: 4%; z-index: 4;
      width: min(58vw, 42rem);
      mix-blend-mode: screen; opacity: 0.75;
      pointer-events: none;
    }

    /* L6 — the portrait breaks the wordmark */
    .portrait {
      position: absolute; right: clamp(0rem, 7vw, 9rem); bottom: 0; z-index: 5;
      height: min(80vh, 92%); width: auto;
      /* never squash the subject: keep true aspect ratio and let it bleed off-frame
         (works for any image shape the owner uploads) */
      max-width: none;
      filter: saturate(1.1) contrast(1.05) drop-shadow(-18px 24px 60px rgba(0,0,0,0.6));
    }

    /* L7 — mist grounding the bottom */
    .mist {
      position: absolute; inset: auto 0 0 0; height: 34%; z-index: 6;
      background: linear-gradient(180deg, transparent, rgba(11,10,14,0.55) 55%, var(--ink));
      pointer-events: none;
    }

    /* L8 — drifting dust motes */
    .dust { position: absolute; inset: 0; z-index: 7; pointer-events: none; }
    .dust span {
      position: absolute; width: 4px; height: 4px; border-radius: 50%;
      background: rgba(255, 220, 150, 0.75); filter: blur(0.5px);
      animation: mote 6s ease-in-out infinite alternate;
    }
    @keyframes mote {
      from { transform: translate(0, 0); opacity: 0; }
      30% { opacity: 0.9; }
      to { transform: translate(18px, -34px); opacity: 0; }
    }

    /* L9 — copy block */
    .copy { position: absolute; left: clamp(1.25rem, 6vw, 5rem); bottom: 10%; z-index: 8; max-width: 34rem; }
    .welcome {
      font-size: clamp(1.6rem, 4vw, 2.4rem); color: var(--danfo);
      text-shadow: 0 2px 16px rgba(0,0,0,0.6); margin-bottom: 0.4rem;
    }
    .lede { max-width: 40ch; font-size: 1.02rem; color: var(--text); text-shadow: 0 1px 10px rgba(0,0,0,0.8); }
    .hero-ctas { display: flex; flex-wrap: wrap; align-items: center; gap: 1.2rem; margin-top: 1.6rem; }

    /* L10 — cinematic color grade: warm highlights, cool shadows, vignette */
    .grade {
      position: absolute; inset: 0; z-index: 9; pointer-events: none;
      background:
        linear-gradient(205deg, rgba(255, 150, 40, 0.18), transparent 42%),
        linear-gradient(25deg, rgba(28, 48, 110, 0.22), transparent 46%),
        radial-gradient(120% 90% at 50% 40%, transparent 60%, rgba(8, 7, 12, 0.5) 100%);
      mix-blend-mode: overlay;
    }

    @media (prefers-reduced-motion: reduce) {
      .bg-img, .clouds, .dust span { animation: none; }
      .birds { display: none; }
    }
    .btn-solid {
      background: var(--danfo); color: #191410; font-weight: 700; text-decoration: none;
      padding: 0.8rem 1.6rem; border-radius: 999px; border: 2px solid #191410; box-shadow: 3px 3px 0 #000;
    }
    .btn-solid:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 #000; }
    .btn-play { display: inline-flex; align-items: center; gap: 0.7rem; text-decoration: none; font-weight: 600; font-size: 0.95rem; text-shadow: 0 1px 8px rgba(0,0,0,0.8); }
    .play {
      display: grid; place-content: center; width: 2.6rem; height: 2.6rem; border-radius: 50%;
      border: 2px solid rgba(243,239,230,0.7); font-size: 0.7rem; padding-left: 2px;
    }
    .btn-play:hover .play { border-color: var(--danfo); color: var(--danfo); }
    .scroll-hint {
      position: absolute; bottom: 1.4rem; left: 50%; transform: translateX(-50%); z-index: 10;
      font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: rgba(243,239,230,0.75);
    }

    .stats {
      display: grid; grid-template-columns: repeat(5, 1fr);
      border-block: 1px solid var(--line);
      background: rgba(22,20,28,0.6); backdrop-filter: blur(8px);
      margin-top: -4.5rem; position: relative; z-index: 2;
      margin-inline: clamp(1rem, 4vw, 3rem); border: 1px solid var(--line); border-radius: 1rem;
      overflow: hidden;
    }
    .stat { display: grid; gap: 0.1rem; place-items: center; padding: 1.3rem 0.5rem; text-align: center; }
    .stat + .stat { border-left: 1px solid var(--line); }
    .stat b { font-family: var(--font-mono); font-size: 1.15rem; color: var(--danfo); }
    .stat span { font-size: 0.78rem; color: var(--text-dim); }

    .explore { padding: 5rem clamp(1rem, 4vw, 3rem) 3rem; }
    .explore-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 1.5rem; margin-bottom: 2rem; }
    .explore-head h2 {
      font-size: clamp(2rem, 5vw, 3rem); color: var(--text); font-weight: 400;
      text-decoration: underline; text-decoration-color: var(--neon-pink); text-decoration-thickness: 3px; text-underline-offset: 10px;
    }
    .explore-head p { color: var(--text-dim); max-width: 34ch; font-size: 0.95rem; }
    .city-row {
      display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem;
    }
    .city-card {
      position: relative; border-radius: 0.9rem; overflow: hidden; text-decoration: none;
      aspect-ratio: 4 / 5; border: 1px solid var(--line);
      transition: transform 0.18s ease;
    }
    .city-card img { width: 100%; height: 100%; object-fit: cover; }
    a.city-card:hover { transform: translateY(-5px); border-color: var(--danfo); }
    .city-meta {
      position: absolute; inset: auto 0 0 0; padding: 2.2rem 0.9rem 0.9rem;
      background: linear-gradient(180deg, transparent, rgba(0,0,0,0.85));
      display: grid; gap: 0.05rem;
    }
    .city-meta strong { font-family: var(--font-display); font-size: 1.15rem; }
    .city-meta span { font-size: 0.75rem; color: var(--text-dim); }
    .cats {
      display: grid; grid-template-columns: repeat(5, 1fr);
      border-top: 1px solid var(--line);
      padding: 2.2rem clamp(1rem, 4vw, 3rem); gap: 1rem;
    }
    .cat { display: grid; gap: 0.15rem; place-items: center; text-align: center; }
    .cat-name { font-size: 1.3rem; text-shadow: 0 0 18px currentColor; }
    .cat-sub { font-size: 0.75rem; color: var(--text-dim); }

    @media (max-width: 56rem) {
      .portrait { height: 46vh; right: -30%; }
      .splash { width: 78vw; right: -22%; }
      .word { inset: 16% 0 auto 0; }
      .copy { bottom: 12%; max-width: 78vw; }
      .stats { grid-template-columns: repeat(2, 1fr); margin-top: 0; border-radius: 0; margin-inline: 0; border-inline: none; }
      .stat:nth-child(odd) { border-left: none; }
      .stat:nth-child(5) { grid-column: span 2; border-left: none; border-top: 1px solid var(--line); }
      .city-row { grid-template-columns: repeat(2, 1fr); }
      .city-card:last-child { grid-column: span 2; aspect-ratio: 16 / 9; }
      .cats { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</Cinematic>
